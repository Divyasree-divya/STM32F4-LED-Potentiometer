int TRIG PA0
int ECHO PA1
int GAS  PA2      

long duration;
float distance;
int gasValue;

void setup()
{
  pinMode(TRIG, OUTPUT);
  pinMode(ECHO, INPUT);
  pinMode(GAS, INPUT);

  Serial.begin(9600);
}

void loop()
{
  
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG, LOW);


  duration = pulseIn(ECHO, HIGH);

 
  distance = duration * 0.0343 / 2;


  gasValue = analogRead(GAS);

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.print(" cm");

  Serial.print("    Gas Sensor: ");
  Serial.println(gasValue);

  delay(500);
}
